{% set fields = Bake.filterFields(fields, schema, modelObject) %}
<?php
$this->assign('title', __('{{ action|humanize }} {{ singularHumanName }}'));
$this->Breadcrumbs->addMany([
    ['title' => __('Home'), 'url' => '/'],
    ['title' => __('List {{ pluralHumanName }}'), 'url' => ['action' => 'index']],
{% if 'add' not in action %}
    ['title' => __('View'), 'url' => ['action' => 'view', ${{ singularVar }}->{{ primaryKey[0] }}]],
    ['title' => __('Edit')],
{% else %}
    ['title' => __('Add')],
{% endif %}
]);
?>

<div class="card card-primary card-outline">
{% if 'add' not in action %}
    <?= $this->Form->create(${{ singularVar }}) ?>
{% else %}
    <?= $this->Form->create(${{ singularVar }}, ['valueSources' => ['query', 'context']]) ?>
{% endif %}
    <div class="card-body">
{% for field in fields %}
{# ✅ add/edit では created_by / modified_by を入力させない（プルダウン化も防ぐ） #}
{% set skipAuditAlways = (field in ['created_by', 'modified_by']) %}

{% if field not in primaryKey and not skipAuditAlways %}

    {# 外部キー（belongsTo 等）ならプルダウン #}
    {% if keyFields[field] %}
        {% set fieldData = Bake.columnData(field, schema) %}
        {% if fieldData.null %}
        <?= $this->Form->control('{{ field }}', ['options' => ${{ keyFields[field] }}, 'empty' => true, 'class' => 'form-control']) ?>
        {% else %}
        <?= $this->Form->control('{{ field }}', ['options' => ${{ keyFields[field] }}, 'class' => 'form-control']) ?>
        {% endif %}

    {% else %}

        {# created/modified 系はフォームに出さない #}
        {% if field not in ['created', 'created_by', 'modified', 'modified_by', 'updated', 'updated_by'] %}
            {% set fieldData = Bake.columnData(field, schema) %}

            {# ✅ password は特別扱い：右端トグル付き #}
            {% if field == 'password' %}
        <div class="form-group">
            <?= $this->Form->label('password', __('Password')) ?>

            <div class="input-group">
                <?= $this->Form->password('password', [
                    'class' => 'form-control js-password-input',
                    'autocomplete' => 'new-password',
                    'value' => '',
                ]) ?>

                <div class="input-group-append">
                    <button type="button"
                            class="btn btn-outline-secondary js-password-toggle"
                            aria-label="<?= __('Show password') ?>"
                            aria-pressed="false">
                        {# 初期：伏字 → 見えるアイコン #}
                        <i class="js-password-icon fas fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        </div>

            {% elseif fieldData.type in ['date', 'datetime', 'time'] and fieldData.null %}
        <?= $this->Form->control('{{ field }}', ['empty' => true]) ?>
            {% elseif fieldData.type in ['boolean'] %}
        <?= $this->Form->control('{{ field }}', ['custom' => true]) ?>
            {% else %}
        <?= $this->Form->control('{{ field }}') ?>
            {% endif %}

        {% endif %}
    {% endif %}

{% endif %}
{% endfor %}

{% if associations.BelongsToMany %}
{% for assocName, assocData in associations.BelongsToMany %}
        <?= $this->Form->control('{{ assocData.property }}._ids', ['options' => ${{ assocData.variable }}]) ?>
{% endfor %}
{% endif %}
    </div>
    <div class="card-footer d-flex">
{% if 'add' not in action %}
        <div class="mr-auto">
            <?= $this->Form->postLink(
                __('Delete'),
                ['action' => 'delete', ${{ singularVar }}->{{ primaryKey[0] }}],
                ['confirm' => __('Are you sure you want to delete # {0}?', ${{ singularVar }}->{{ primaryKey[0] }}), 'class' => 'btn btn-danger']
            ) ?>
        </div>
{% endif %}
        <div class="ml-auto">
            <?= $this->Form->button(__('Save'), ['class' => 'btn btn-primary']) ?>
{% if 'add' not in action %}
            <?= $this->Html->link(__('Cancel'), ['action' => 'view', ${{ singularVar }}->{{ primaryKey[0] }}], ['class' => 'btn btn-default']) ?>
{% else %}
            <?= $this->Html->link(__('Cancel'), ['action' => 'index'], ['class' => 'btn btn-default']) ?>
{% endif %}
        </div>
    </div>
    <?= $this->Form->end() ?>
</div>

{# ✅ password トグル用 JS（フォームがあるページだけで動く） #}
<script>
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.js-password-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.input-group');
      if (!group) return;

      const input = group.querySelector('.js-password-input');
      const icon  = btn.querySelector('.js-password-icon');
      if (!input || !icon) return;

      const show = (input.type === 'password');

      // 入力タイプ切替
      input.type = show ? 'text' : 'password';

      // aria
      btn.setAttribute('aria-pressed', show ? 'true' : 'false');
      btn.setAttribute('aria-label', show ? 'Hide password' : 'Show password');

      // 次の操作を示すアイコンに切替
      icon.classList.toggle('fa-eye-slash', show);
      icon.classList.toggle('fa-eye', !show);
    });
  });
});
</script>
